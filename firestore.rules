rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Адміном вважаємо лише того, хто залогінений і має документ
    // у колекції admins з таким email (у нижньому регістрі, як і скрізь у коді).
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower()));
    }

    // ==========================================================
    // 1. ПОВНИЙ ДОСТУП — ТІЛЬКИ СХВАЛЕНИМ АДМІНАМ
    // ==========================================================
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // ==========================================================
    // 2. ДОСТУП ДЛЯ ЗВИЧАЙНИХ ВІДВІДУВАЧІВ (ПОКУПЦІВ)
    // ==========================================================

    // Публічні дані — дозволяємо тільки БАЧИТИ товари та контент
    match /merch/{docId} { allow read: if true; }
    match /news/{docId} { allow read: if true; }
    match /reports/{docId} { allow read: if true; }
    match /promocodes/{docId} { allow read: if true; }
    match /config/{docId} { allow read: if true; }
    match /admins/{docId} { allow read: if true; }
    match /hub_links/{docId} { allow read: if true; } // Читання мультипосилань

    // Форми, замовлення та КЛІКИ — дозволяємо клієнтам ВІДПРАВЛЯТИ дані,
    // а замовлення ще й ЧИТАТИ — бо status.html шукає замовлення по номеру
    // телефону (db.collection("orders").where("phone","==",...)), і без
    // права на read цей пошук завжди повертав би "заборонено".
    match /orders/{docId} { allow create: if true; allow read: if true; }
    match /volunteers/{docId} { allow create: if true; }
    match /feedback/{docId} { allow create: if true; }
    match /hub_clicks/{docId} { allow create: if true; allow read: if isAdmin(); } // Запис кліків для аналітики

    // Заявки на доступ — будь-хто може СТВОРИТИ заявку (реєстрація),
    // але читати/видаляти список заявок може тільки адмін.
    match /admin_requests/{docId} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }

    // Анонімний чат — дозволяємо відвідувачам писати та читати свої повідомлення
    match /chats/{docId} {
      allow read, write: if true;
    }
  }
}
